    {
      "id": "autocorrect-insistence",
      "title": "Autocorrect Won't Take No For An Answer",
      "subtitle": "You fixed it. It unfixed it. You fixed it again. It unfixed it again.",
      "description": "You type a word. Autocorrect changes it. You delete it and type what you meant. Autocorrect changes it again. You fix it AGAIN. It changes it AGAIN. You've now manually corrected this word twice, clearly signaling you want it this way. Autocorrect doesn't care. It will die on this hill.",
      "platforms": ["iOS", "iPadOS", "macOS"],
      "screenshot": "screenshots/autocorrect-insistence.png",
